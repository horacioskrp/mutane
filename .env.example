# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=mutane
DB_SSLMODE=disable

# Ou utilisez une DSN complète (prioritaire sur les variables ci-dessus) :
# DATABASE_URL=postgres://postgres:password@localhost:5432/mutane?sslmode=disable

# ── Auth ──────────────────────────────────────────────────────────────────────
# Générez avec : openssl rand -hex 32
JWT_SECRET=change-me-with-a-long-random-string-min-32-chars

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
UPLOAD_BASE_URL=http://localhost:8080/uploads
